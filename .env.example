# =====================================================
# CONFIGURAÇÕES DE AMBIENTE - FARMÁCIA MÃO AMIGA
# Copie este arquivo para .env e preencha os valores
# =====================================================

# Banco de Dados
DB_HOST=localhost
DB_NAME=nome_do_banco
DB_USER=usuario_do_banco
DB_PASS=senha_do_banco
DB_CHARSET=utf8mb4
TABLE_PREFIX=farmacia_

# Aplicação
APP_NAME=Farmácia Mão Amiga
APP_ENV=production
APP_URL=http://localhost:8000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=noreply@farmaciapopular.com.br
SMTP_FROM_NAME=Farmácia Mão Amiga
